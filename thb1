<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Hiring Bureau | Recruitment, HR & Careers</title>
    <style>
        /* Reset & Base Styles */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --bg-dark: #0b0b0b;
            --bg-card: #141414;
            --gold-primary: #d4af37;
            --gold-hover: #f3e5ab;
            --text-light: #ffffff;
            --text-muted: #cccccc;
            --border-gold: rgba(212, 175, 55, 0.3);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Navigation */
        header {
            background-color: rgba(11, 11, 11, 0.95);
            border-bottom: 1px solid var(--border-gold);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-text {
            color: var(--gold-primary);
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 30px;
        }

        .nav-links a {
            color: var(--text-light);
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: color 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .nav-links a:hover {
            color: var(--gold-primary);
        }

        /* Hero Section */
        .hero {
            padding: 180px 20px 100px 20px;
            text-align: center;
            background: radial-gradient(circle at center, #1a1a1a 0%, #0b0b0b 100%);
            border-bottom: 1px solid var(--border-gold);
        }

        .hero h1 {
            font-size: 48px;
            color: var(--gold-primary);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .hero .tagline {
            font-size: 22px;
            font-style: italic;
            color: var(--text-muted);
            margin-bottom: 40px;
        }

        .hero-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-block;
            padding: 15px 35px;
            border-radius: 4px;
            text-decoration: none;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background-color: var(--gold-primary);
            color: #000;
            border: 1px solid var(--gold-primary);
        }

        .btn-primary:hover {
            background-color: transparent;
            color: var(--gold-primary);
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-light);
            border: 1px solid var(--text-light);
        }

        .btn-secondary:hover {
            border-color: var(--gold-primary);
            color: var(--gold-primary);
        }

        /* Services / Industries */
        .section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 20px;
        }

        .section-title {
            text-align: center;
            font-size: 32px;
            color: var(--gold-primary);
            margin-bottom: 50px;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 2px;
            background-color: var(--gold-primary);
            margin: 15px auto 0 auto;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 40px 30px;
            border-radius: 6px;
            text-align: center;
            transition: transform 0.3s ease, border-color 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: var(--gold-primary);
        }

        .card h3 {
            color: var(--gold-primary);
            margin-bottom: 15px;
            font-size: 20px;
            text-transform: uppercase;
        }

        /* Split Sections for Candidates & Employers */
        .split-section {
            background-color: var(--bg-card);
            border-top: 1px solid var(--border-gold);
            border-bottom: 1px solid var(--border-gold);
        }

        .split-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
        }

        @media (max-width: 768px) {
            .split-grid {
                grid-template-columns: 1fr;
            }
        }

        .split-col {
            padding: 80px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .split-col:first-child {
            border-right: 1px solid var(--border-gold);
        }

        @media (max-width: 768px) {
            .split-col:first-child {
                border-right: none;
                border-bottom: 1px solid var(--border-gold);
            }
        }

        .split-col h2 {
            font-size: 28px;
            color: var(--gold-primary);
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .split-col p {
            margin-bottom: 30px;
            color: var(--text-muted);
        }

        /* Security Banner */
        .security-badge {
            background-color: rgba(212, 175, 55, 0.05);
            border: 1px solid var(--border-gold);
            padding: 15px;
            border-radius: 4px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-top: 40px;
            font-size: 14px;
            color: var(--text-muted);
        }

        .security-badge svg {
            fill: var(--gold-primary);
            width: 18px;
            height: 18px;
        }

        /* Footer */
        footer {
            background-color: #050505;
            padding: 40px 20px;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-links {
            margin-bottom: 20px;
        }

        .footer-links a {
            color: var(--text-muted);
            text-decoration: none;
            margin: 0 15px;
            font-size: 14px;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--gold-primary);
        }

        .copyright {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.4);
        }

        /* Mobile Menu Toggle */
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            background: none;
            border: none;
        }

        .menu-toggle span {
            display: block;
            width: 25px;
            height: 2px;
            background-color: var(--gold-primary);
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 70px;
                left: 0;
                width: 100%;
                background-color: var(--bg-dark);
                border-bottom: 1px solid var(--border-gold);
                padding: 20px;
                text-align: center;
                gap: 20px;
            }

            .nav-links.active {
                display: flex;
            }

            .menu-toggle {
                display: flex;
            }

            .hero h1 {
                font-size: 34px;
            }

            .hero .tagline {
                font-size: 18px;
            }
        }
    </style>
</head>
<body>

    <!-- Header & Navigation -->
    <header>
        <div class="nav-container">
            <a href="#" class="logo-text">THB</a>
            <button class="menu-toggle" id="mobile-menu" aria-label="Toggle Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-links" id="nav-list">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#candidates">For Candidates</a></li>
                <li><a href="#employers">For Employers</a></li>
            </ul>
        </div>
    </header>

    <!-- Home / Hero Section -->
    <section class="hero" id="home">
        <h1>The Hiring Bureau</h1>
        <p class="tagline">The right fit</p>
        <p style="max-width: 600px; margin: 0 auto 40px auto; color: var(--text-muted);">
            Premier executive search, talent acquisition, and workforce solutions across all corporate domains and industries globally.
        </p>
        <div class="hero-buttons">
            <a href="https://wa.me/9249068335" class="btn btn-primary" target="_blank">Submit CV via WhatsApp</a>
            <a href="mailto:hr@thehiringbureau.com" class="btn btn-secondary">Submit Requirements</a>
        </div>
        
        <div class="security-badge">
            <svg viewBox="0 0 24 24">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
            </svg>
            SSL Secure End-to-End Encrypted Data Transmission
        </div>
    </section>

    <!-- About / Industries Section -->
    <section class="section" id="about">
        <h2 class="section-title">Global Industry Coverage</h2>
        <p style="text-align: center; max-width: 700px; margin: -20px auto 50px auto; color: var(--text-muted);">
            We strictly cater to all major corporate sectors, delivering custom recruitment strategy and seamless staffing operations.
        </p>
        <div class="grid">
            <div class="card">
                <h3>Corporate & IT</h3>
                <p style="color: var(--text-muted);">Top-tier engineering, architecture, software development, and modern leadership roles.</p>
            </div>
            <div class="card">
                <h3>Healthcare & Medical</h3>
                <p style="color: var(--text-muted);">Specialized healthcare personnel, clinicians, administrative staff, and executive teams.</p>
            </div>
            <div class="card">
                <h3>Finance & Engineering</h3>
                <p style="color: var(--text-muted);">Experienced financial officers, project engineers, analysts, and operations managers.</p>
            </div>
        </div>
    </section>

    <!-- Split Candidates & Employers Section -->
    <section class="split-section">
        <div class="split-grid">
            <!-- Candidates -->
            <div class="split-col" id="candidates">
                <h2>For Candidates</h2>
                <p>Advance your career with elite placements. We accept submissions from qualified talent spanning all skill levels and industry sectors.</p>
                <div style="margin-bottom: 25px;">
                    <strong style="color: var(--gold-primary); display: block; margin-bottom: 5px;">How to Apply:</strong>
                    <p style="margin-bottom: 10px;">• Direct message your CV on WhatsApp: <strong>+91 9249068335</strong></p>
                    <p>• Send via email to: <strong>thehiringbureau@gmail.com</strong></p>
                </div>
                <div>
                    <a href="https://wa.me/9249068335" class="btn btn-primary" style="margin-right: 15px;" target="_blank">WhatsApp CV</a>
                    <a href="mailto:thehiringbureau@gmail.com" class="btn btn-secondary">Email CV</a>
                </div>
            </div>

            <!-- Employers -->
            <div class="split-col" id="employers">
                <h2>For Employers</h2>
                <p>Source vetted professionals who align perfectly with your organization's technical needs and corporate culture.</p>
                <div style="margin-bottom: 25px;">
                    <strong style="color: var(--gold-primary); display: block; margin-bottom: 5px;">Submit Mandates:</strong>
                    <p>Email your current workforce requirements and job descriptions to our client relations division:</p>
                    <p style="margin-top: 10px; font-weight: bold; font-size: 18px; color: var(--gold-primary);">hr@thehiringbureau.com</p>
                </div>
                <div>
                    <a href="mailto:hr@thehiringbureau.com" class="btn btn-primary">Connect with HR</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-links">
            <a href="https://instagram.com/thehiringbureau" target="_blank">Instagram: @thehiringbureau</a>
            <a href="tel:9249068335">Call: 9249068335</a>
        </div>
        <p class="copyright">&copy; 2026 The Hiring Bureau. All Rights Reserved. RECRUITMENT | HR | CAREERS</p>
    </footer>

    <!-- Mobile Navigation Script -->
    <script>
        const mobileMenu = document.getElementById('mobile-menu');
        const navList = document.getElementById('nav-list');

        mobileMenu.addEventListener('click', () => {
            navList.classList.toggle('active');
        });

        // Close menu when a link is clicked
        document.querySelectorAll('.nav-links a').forEach(link => {
            link.addEventListener('click', () => {
                navList.classList.remove('active');
            });
        });
    </script>
</body>
</html>
